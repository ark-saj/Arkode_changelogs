# Arkode Centro de Novedades — environment contract.
# Copy to .env.local for local dev. Values below are the WELL-KNOWN LOCAL
# Supabase demo keys (public, safe for local only). Set real secrets in prod.

# --- Public (browser-safe) ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
NEXT_PUBLIC_TENANT=conecta

# --- Server-only (NEVER expose to the browser) -------------------------------
# Write layer (Fase 2). service_role bypasses RLS; the write boundary is
# ChangelogService (tenantId mandatory). REQUIRED in production.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# --- Agent adapters (MCP server / CLI) ---------------------------------------
# Per-tenant write tokens (slug=token,...). Each token writes to ONE tenant.
ARK_API_BASE_URL=http://127.0.0.1:3000
ARK_TOKENS=conecta=ark_conecta_devtoken,everban=ark_everban_devtoken
